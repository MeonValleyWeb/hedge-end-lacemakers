---
import Layout from '../layouts/Layout.astro';

const suppliers = {
  guild: {
    name: "The Lace Guild",
    url: "https://www.laceguild.org",
    description: "The Lace Guild is your destination for the stunning art of lace and lace making! Nestled at The Hollies near Stourbridge, the museum is filled with rich history and endless inspiration. Become a member to engage with local groups, explore the charm of vintage lace, and enjoy your quarterly journal."
  },
  general: [
    { name: "Roseground", url: "https://www.roseground.com/" },
    { name: "Claire's Lace", url: "https://claireslace.co.uk/shop/index.php" },
    { name: "Mainly Lace", url: "https://mainlylace.co.uk/" },
    { name: "Harlequin", url: "http://www.harlequinlace.com" }
  ],
  bobbins: [
    { name: "Stuart Johnson", url: "http://www.stuartjohnsonslacebobbinshop.co.uk/" },
    { name: "Archer Bobbins", url: "http://www.ararcherltd.co.uk" },
    { name: "Chris Parsons", url: "http://www.thebobbinshop.com" },
    { name: "Margaret Wall", email: "mwallbobbins@btinternet.com" },
    { name: "Alison Tolson", url: "https://www.lacebobbin.com" },
    { name: "Eddy Faber", url: "https://www.etsy.com/uk/shop/EddyFaberBobbins" }
  ],
  accessories: [
    { name: "Pat Castlo", email: "pat.castlo65@gmail.com", note: "Pillow bags, etc" },
    { name: "Jens Beads", email: "Jensbeads@btinternet.com" },
    { name: "Loo Woo Designs", url: "http://www.thecraftcorner.co.uk" },
    { name: "Spangles", url: "http://www.spangles4beads.co.uk" },
    { name: "Louise West Lace Design", url: "https://shop.louisewestlacedesign.co.uk/" },
    { name: "Anne Spencer", url: "http://www.lacemakingaccessories.co.uk" },
    { name: "Skein Queen", url: "https://www.skeinqueenyarns.co.uk" },
    { name: "Ann Bird Lace Bags", email: "annbirdlacebags@gmail.com" },
    { name: "Lighthouse Glass (beads)", url: "http://www.lighthouseglass.co.uk" }
  ]
};
---

<Layout title="Lace Suppliers" description="Find quality lace making suppliers including bobbins, thread, accessories, and more. Supporting UK lacemaking businesses.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-lace-100 via-cream-100 to-lace-200 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="font-serif text-4xl lg:text-5xl font-bold text-gray-900 mb-6">
          Lace <span class="text-lace-600">Suppliers</span>
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed">
          Quality suppliers for all your lace making needs. From bobbins and thread to 
          accessories and specialty items — everything you need for your lace projects.
        </p>
      </div>
    </div>
  </section>

  <!-- The Lace Guild -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-lace-600 to-lace-700 rounded-2xl overflow-hidden shadow-lg">
        <div class="grid md:grid-cols-2">
          <div class="p-8 lg:p-12">
            <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full text-white text-sm font-medium mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
              Recommended
            </div>
            <h2 class="font-serif text-3xl font-bold text-white mb-4">{suppliers.guild.name}</h2>
            <p class="text-lace-100 leading-relaxed mb-6">{suppliers.guild.description}</p>
            <a href={suppliers.guild.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-white text-lace-700 px-6 py-3 rounded-lg font-semibold hover:bg-lace-50 transition-colors">
              Visit Website
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </a>
          </div>
          <div class="relative bg-lace-800 flex items-center justify-center p-8">
            <div class="text-center text-white">
              <div class="text-6xl mb-4">🏛️</div>
              <p class="font-serif text-xl">The Hollies</p>
              <p class="text-lace-300">Stourbridge</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- General Suppliers -->
  <section class="py-12 lg:py-16 bg-cream-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-xl">🧵</span>
        General Suppliers
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {suppliers.general.map(supplier => (
          <a href={supplier.url} target="_blank" rel="noopener" class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-all group">
            <h3 class="font-semibold text-gray-900 group-hover:text-lace-600 transition-colors">{supplier.name}</h3>
            <p class="text-sm text-gray-500 mt-1 flex items-center gap-1">
              Visit website
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Bobbins -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center text-xl">🪡</span>
        Bobbins
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {suppliers.bobbins.map(supplier => (
          <div class="bg-cream-100 rounded-xl p-6">
            <h3 class="font-semibold text-gray-900">{supplier.name}</h3>
            {supplier.url ? (
              <a href={supplier.url} target="_blank" rel="noopener" class="text-sm text-lace-600 hover:text-lace-700 flex items-center gap-1 mt-2">
                Visit website
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            ) : supplier.email ? (
              <a href={`mailto:${supplier.email}`} class="text-sm text-lace-600 hover:text-lace-700 flex items-center gap-1 mt-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                {supplier.email}
              </a>
            ) : null}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accessories -->
  <section class="py-12 lg:py-16 bg-cream-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl font-bold text-gray-900 mb-8 flex items-center gap-3">
        <span class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center text-xl">✂️</span>
        Accessories
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {suppliers.accessories.map(supplier => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900">{supplier.name}</h3>
            {supplier.note && <p class="text-sm text-gray-500 mt-1">{supplier.note}</p>}
            {supplier.url ? (
              <a href={supplier.url} target="_blank" rel="noopener" class="text-sm text-lace-600 hover:text-lace-700 flex items-center gap-1 mt-2">
                Visit website
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            ) : supplier.email ? (
              <a href={`mailto:${supplier.email}`} class="text-sm text-lace-600 hover:text-lace-700 flex items-center gap-1 mt-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Email
              </a>
            ) : null}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-8 bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-gray-500 text-center">
        We are not affiliated with any of these suppliers. Please contact them directly for inquiries about products and services.
      </p>
    </div>
  </section>
</Layout>