---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Members Login" description="Members area for Hedge End Bobbin Lacemakers. Access exclusive content and resources.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-lace-600 to-lace-800 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
        </svg>
      </div>
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-4">Members Area</h1>
      <p class="text-xl text-lace-200 max-w-2xl mx-auto">
        Exclusive content and resources for Hedge End Bobbin Lacemakers members
      </p>
    </div>
  </section>

  <!-- Login Form -->
  <section class="py-12 lg:py-16 bg-cream-100">
    <div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <h2 class="font-serif text-2xl font-bold text-gray-900 mb-2 text-center">Member Login</h2>
        <p class="text-gray-600 text-center mb-6">Enter your credentials to access the members area</p>

        <form class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
            <input type="email" id="email" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-lace-500 focus:ring-2 focus:ring-lace-200 outline-none transition-all" placeholder="your@email.com" />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Password</label>
            <input type="password" id="password" class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-lace-500 focus:ring-2 focus:ring-lace-200 outline-none transition-all" placeholder="••••••••" />
          </div>

          <div class="flex items-center justify-between text-sm">
            <label class="flex items-center gap-2">
              <input type="checkbox" class="rounded border-gray-300 text-lace-600 focus:ring-lace-500" />
              <span class="text-gray-600">Remember me</span>
            </label>
            <a href="#" class="text-lace-600 hover:text-lace-700">Forgot password?</a>
          </div>

          <button type="submit" class="w-full bg-lace-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-lace-700 transition-colors">
            Sign In
          </button>
        </form>

        <div class="mt-6 pt-6 border-t border-gray-200 text-center">
          <p class="text-sm text-gray-600">
            Not a member yet? <a href="/contact" class="text-lace-600 hover:text-lace-700 font-medium">Join our classes</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Member Benefits -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-2xl font-bold text-gray-900 text-center mb-8">Member Benefits</h2>
      
      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex items-start gap-4 p-6 bg-cream-100 rounded-xl">
          <div class="w-12 h-12 bg-lace-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-lace-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Pattern Library</h3>
            <p class="text-sm text-gray-600">Access our collection of exclusive patterns and tutorials</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-6 bg-cream-100 rounded-xl">
          <div class="w-12 h-12 bg-lace-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-lace-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Event Calendar</h3>
            <p class="text-sm text-gray-600">View and book upcoming workshops and outings</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-6 bg-cream-100 rounded-xl">
          <div class="w-12 h-12 bg-lace-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-lace-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Member Directory</h3>
            <p class="text-sm text-gray-600">Connect with fellow lacemakers in our community</p>
          </div>
        </div>

        <div class="flex items-start gap-4 p-6 bg-cream-100 rounded-xl">
          <div class="w-12 h-12 bg-lace-100 rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-lace-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 mb-1">Photo Gallery</h3>
            <p class="text-sm text-gray-600">Browse and share photos of your lace creations</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Note -->
  <section class="py-8 bg-lace-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-gray-600">
        <strong>Note:</strong> The members area is currently being set up. 
        Existing members will receive login credentials via email once it's ready.
      </p>
    </div>
  </section>
</Layout>