---
import Layout from '../layouts/Layout.astro';

const events2026 = [
  {
    type: "demonstration",
    title: "Tudor House Museum Demonstration",
    date: "Saturday 17th May 2026",
    description: "We'll be demonstrating our lace-making skills at Southampton's oldest museum.",
    link: "https://tudorhouseandgarden.com/",
    linkText: "Visit Tudor House & Garden",
    confirmed: true
  },
  {
    type: "demonstration",
    title: "RVCP Demonstration",
    date: "Saturday 12th September 2026",
    description: "We hope to be demonstrating at Royal Victoria Country Park.",
    confirmed: false
  },
  {
    type: "workshop",
    title: "2-Day Milanese Workshop",
    date: "July 2026 (Dates TBC)",
    description: "Intensive two-day workshop focusing on Milanese lace techniques.",
    status: "FULL"
  },
  {
    type: "workshop",
    title: "JUST LACE - 4 Day Workshop",
    date: "2nd, 3rd, 4th & 5th October 2026",
    description: "Our annual 4-day workshop for class members only. A wonderful opportunity to immerse yourself in lacemaking.",
    confirmed: true
  },
  {
    type: "workshop",
    title: "Mounting Workshop",
    date: "Sunday 1st November 2026 (Boorley Green)",
    description: "Learn how to properly mount and finish your lace pieces. Please sign up now if you wish to attend.",
    confirmed: true
  },
  {
    type: "workshop",
    title: "Milanese 2-Day Workshop",
    date: "28th & 29th November 2026",
    description: "Another opportunity to learn Milanese techniques in this weekend workshop.",
    confirmed: true
  },
  {
    type: "outing",
    title: "Christmas Fair Trip",
    date: "5th December 2026",
    description: "Possible trip by coach/minibus to a Christmas Fair. More details to follow.",
    confirmed: false
  }
];

const laceDay = {
  title: "1st Lace Day",
  date: "Saturday 25th April 2026",
  ticketLink: "https://www.ticketsource.co.uk/hedgeend1stlaceday/hedge-end-bobbin-lacemakers-1st-lace-day/2026-04-25/10:00/t-qjolreq",
  charity: "Hampshire & Isle of Wight Air Ambulance",
  price: "From £7.50"
};
---

<Layout title="Events 2026" description="Join Hedge End Bobbin Lacemakers for demonstrations, workshops, and our special Lace Day event in 2026.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-lace-600 to-lace-800 py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-4">2026 Events</h1>
      <p class="text-xl text-lace-200 max-w-2xl mx-auto">
        Demonstrations, workshops, outings, and our special Lace Day — there's something for everyone!
      </p>
    </div>
  </section>

  <!-- Lace Day Highlight -->
  <section class="py-12 lg:py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-r from-amber-100 to-orange-100 rounded-2xl p-8 lg:p-12 border-2 border-amber-200">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-amber-500 text-white px-3 py-1 rounded-full text-sm font-bold">FEATURED EVENT</span>
          <span class="text-2xl">🎉</span>
        </div>
        <h2 class="font-serif text-3xl lg:text-4xl font-bold text-gray-900 mb-2">Our {laceDay.title}</h2>
        <p class="text-xl text-amber-700 font-medium mb-4">{laceDay.date}</p>
        <p class="text-gray-700 mb-6">
          Join us for our first-ever Lace Day! Suppliers will be in attendance, we'll have a guest speaker, 
          and all proceeds support {laceDay.charity}.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={laceDay.ticketLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-amber-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-amber-600 transition-colors">
            Buy Tickets — {laceDay.price}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
          <a href="/" class="inline-flex items-center gap-2 bg-white text-amber-700 border-2 border-amber-300 px-6 py-3 rounded-lg font-medium hover:bg-amber-50 transition-colors">
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Events List -->
  <section class="py-12 lg:py-16 bg-cream-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Demonstrations -->
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
          <span class="w-10 h-10 bg-purple-100 rounded-full flex items-center justify-center text-xl">🎭</span>
          Demonstrations
        </h2>
        <div class="space-y-4">
          {events2026.filter(e => e.type === "demonstration").map(event => (
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-shadow">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="font-serif text-xl font-semibold text-gray-900">{event.title}</h3>
                  <p class="text-lace-600 font-medium">{event.date}</p>
                </div>
                {event.confirmed ? (
                  <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium">Confirmed</span>
                ) : (
                  <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-sm font-medium">TBC</span>
                )}
              </div>
              <p class="text-gray-600 mb-3">{event.description}</p>
              {event.link && (
                <a href={event.link} target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-lace-600 font-medium hover:text-lace-700">
                  {event.linkText}
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                  </svg>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Workshops -->
      <div class="mb-12">
        <h2 class="font-serif text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
          <span class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-xl">🧵</span>
          Workshops
        </h2>
        <div class="space-y-4">
          {events2026.filter(e => e.type === "workshop").map(event => (
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-shadow">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="font-serif text-xl font-semibold text-gray-900">{event.title}</h3>
                  <p class="text-lace-600 font-medium">{event.date}</p>
                </div>
                {event.status === "FULL" ? (
                  <span class="bg-red-100 text-red-700 px-3 py-1 rounded-full text-sm font-medium">Fully Booked</span>
                ) : event.confirmed ? (
                  <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium">Spaces Available</span>
                ) : null}
              </div>
              <p class="text-gray-600">{event.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Outings -->
      <div>
        <h2 class="font-serif text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
          <span class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-xl">🚌</span>
          Outings
        </h2>
        <div class="space-y-4">
          {events2026.filter(e => e.type === "outing").map(event => (
            <div class="bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-shadow">
              <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
                <div>
                  <h3 class="font-serif text-xl font-semibold text-gray-900">{event.title}</h3>
                  <p class="text-lace-600 font-medium">{event.date}</p>
                </div>
                {event.confirmed ? (
                  <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium">Confirmed</span>
                ) : (
                  <span class="bg-amber-100 text-amber-700 px-3 py-1 rounded-full text-sm font-medium">TBC</span>
                )}
              </div>
              <p class="text-gray-600">{event.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 lg:py-16 bg-lace-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-2xl lg:text-3xl font-bold text-white mb-4">Want to Attend?</h2>
      <p class="text-lace-200 mb-6">Contact us for more information about any of our events or workshops.</p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-white text-lace-900 px-6 py-3 rounded-lg font-semibold hover:bg-lace-50 transition-colors">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>